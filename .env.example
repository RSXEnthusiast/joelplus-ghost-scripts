# Copy this file to .env (in the same directory as the scripts) and fill in
# the values for your setup. Lines starting with # are comments.
#
# The scripts source this file automatically if it exists next to them, so
# nothing else needs to be configured to pick it up. .env is gitignored so
# your secrets never get committed. State files (seen-post/video id lists)
# are also written next to the scripts automatically -- there's no separate
# directory to configure.
#
# NOTE: this file is parsed as bash, so always wrap values in double quotes
# (as below) -- an unquoted value containing a space will break sourcing.

# =============================================================================
# SHARED — used by both scripts
# =============================================================================

# Your Ghost site URL, no trailing slash.
GHOST_URL="https://joelplus.com"

# Ghost Admin API key, in the "id:secret" format Ghost gives you.
# Create one at: Ghost Admin -> Settings -> Integrations -> Custom Integrations
# -> Add Custom Integration. Copy the "Admin API Key" value shown there.
GHOST_ADMIN_KEY="REPLACE"

# Slug of the Ghost newsletter to send published posts through. If you use the
# default newsletter, the default value below may already work. Verify by
# inspecting the newsletter's settings page in the F12 browser inspector.
GHOST_NEWSLETTER_SLUG="default-newsletter"

# =============================================================================
# crosspost-youtube-posts.sh
# =============================================================================

# The YouTube channel ID to watch for Community posts. This is NOT the
# @handle -- it's the unique UC... id YouTube generates. Use a YouTube channel
# ID finder if you only know the handle.
YOUTUBE_CHANNEL_ID="REPLACE"

# Ghost tag applied to posts cross-posted from YouTube.
YOUTUBE_GHOST_TAG="YT Community Posts"

# Visibility of the cross-posted Ghost post. One of Ghost's visibility values:
#   public  -> anyone can see it
#   members -> logged-in members only (free + paid)
#   paid    -> paid (+comped) members only
# Defaults to "public" if unset.
YOUTUBE_GHOST_VISIBILITY="public"

# Who gets the emailed post. Leave unset (recommended) to send to the same
# audience the post is visible to: paid -> paid members, anything else -> all
# members. Set explicitly to override:
#   all           -> everyone; free members get a paywalled teaser + upgrade CTA
#   status:-free  -> paid (+comped) members only
#   status:free   -> free members only
# YOUTUBE_GHOST_EMAIL_SEGMENT="all"

# Icon image shown in the Ghost bookmark card (e.g. a YouTube logo).
YOUTUBE_BOOKMARK_ICON="https://joelplus.com/YT-Icon.png"

# Fallback thumbnail used in the bookmark card when a post has no image.
YOUTUBE_BOOKMARK_THUMBNAIL="https://joelplus.com/default-thumbnail-thing"

# =============================================================================
# peertube-non-main-video-update-post.sh
# =============================================================================

# PeerTube instance URL, no trailing slash.
PEERTUBE_URL="https://joeltube.com"

# Comma-separated list of PeerTube channel handles to watch for new videos.
# Use the local channel "name" (the part before @ in a handle), e.g. for
# joel_channel@joeltube.com use "joel_channel".
PEERTUBE_CHANNELS="menko_the_cat,joel_kalich_walks,joels_junk,joel_kalich_drums,joelk111_gaming"

# PeerTube account credentials. The account must be able to edit the target
# playlist.
PEERTUBE_USERNAME="REPLACE"
PEERTUBE_PASSWORD="REPLACE"

# Channel (numeric id or handle) that owns the created playlist. Required to
# create a playlist, i.e. whenever PEERTUBE_DATED_PLAYLIST=1 or
# PEERTUBE_PLAYLIST_ID is empty.
# Must be a channel owned by the PEERTUBE_USERNAME above.
PEERTUBE_PLAYLIST_CHANNEL_ID="REPLACE"

# Visibility of created playlists: Public, Unlisted, or Private (case-insensitive).
# Only applies when the script creates a playlist (see PEERTUBE_PLAYLIST_CHANNEL_ID
# above) -- it has no effect on an existing playlist reused via PEERTUBE_PLAYLIST_ID.
PEERTUBE_PLAYLIST_VISIBILITY="Unlisted"

# 1 = create a fresh playlist every run, named with the run date (requires
#     PEERTUBE_PLAYLIST_CHANNEL_ID). PEERTUBE_PLAYLIST_ID is ignored.
# 0 = use the single persistent playlist in PEERTUBE_PLAYLIST_ID (or create
#     one named PEERTUBE_PLAYLIST_NAME if PEERTUBE_PLAYLIST_ID is empty).
PEERTUBE_DATED_PLAYLIST="1"

# Dated-playlist mode only: text before the date, separator, and strftime
# format used to build the playlist name, e.g. "New videos — July 6, 2026".
PEERTUBE_PLAYLIST_NAME_PREFIX="New videos"
PEERTUBE_PLAYLIST_NAME_SEP="—"
PEERTUBE_PLAYLIST_DATE_FMT="%B %-d, %Y"

# Non-dated mode only: id of an existing playlist to reuse. Leave blank to
# create one named PEERTUBE_PLAYLIST_NAME instead.
# If the existing playlist is Unlisted or Private, you MUST use its UUID here,
# not its numeric id -- PeerTube only allows numeric-id lookups for Public
# playlists. Find the UUID in the playlist's watch URL or via the API.
PEERTUBE_PLAYLIST_ID=""

# Non-dated mode only: name to use when creating the persistent playlist.
PEERTUBE_PLAYLIST_NAME="New videos"

# How many recent videos to inspect per channel each run (newest first).
PEERTUBE_FETCH_COUNT="100"

# 1 = skip currently-live streams that haven't finished yet.
PEERTUBE_SKIP_LIVES="1"

# Who gets the emailed digest. Leave unset (recommended) to send to the same
# audience the post is visible to (set by PEERTUBE_GHOST_VISIBILITY below):
# paid -> paid members, anything else -> all members. Set explicitly to override:
#   status:-free  -> paid (+comped) members only
#   all           -> everyone; free members get a paywalled teaser + upgrade CTA
#   status:free   -> free members only
# PEERTUBE_GHOST_EMAIL_SEGMENT="status:-free"

# Ghost tag applied to the weekly PeerTube digest post.
PEERTUBE_GHOST_TAG="Sunday Sidecar"

# Visibility of the Ghost digest post. One of Ghost's visibility values:
#   public  -> anyone can see it
#   members -> logged-in members only (free + paid)
#   paid    -> paid (+comped) members only
# Defaults to "paid" if unset.
PEERTUBE_GHOST_VISIBILITY="paid"

# ref= query param appended to outbound links, for analytics.
PEERTUBE_LINK_REF="joelplus.com"
